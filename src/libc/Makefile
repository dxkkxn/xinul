SHELL = /bin/sh
LIB_NAME ?= libc
BUILD_DIR ?= ../build
OBJ_DIR = $(BUILD_DIR)/$(LIB_NAME)_objs
LIB ?= $(BUILD_DIR)/$(LIB_NAME).a

all: $(LIB)

#
# Architecture and hardware selection
#

DEFAULT_HOSTARCH = rv64
HOSTARCH ?= $(DEFAULT_HOSTARCH)
ARCH_DIR = arch/$(HOSTARCH)

#
# Import cros-compile properties : tools, CFlags and  LDFlags
#

include ../arch_config/$(HOSTARCH)/make.config

#
# Headers and objects
#

INCLUDE_DIRS = include include/$(ARCH_DIR)

LIB_DIRS = stdin stdlib stdio string drivers $(ARCH_DIR)
LIB_SRC = $(sort $(foreach d, $(LIB_DIRS), $(wildcard $(d)/*.c)))
LIB_ASM = $(sort $(foreach d, $(LIB_DIRS), $(wildcard $(d)/*.s)))
OBJS = $(LIB_SRC:.c=.o) $(LIB_ASM:.s=.o)
OBJS := $(addprefix $(OBJ_DIR)/, $(OBJS))
DEPFILES = $(OBJS:.o=.d)

#
# CFlags
#

# Default optim and debug options
CFLAGS ?= -O0 -g

# common  arch options
CFLAGS += \
	-mcmodel=medany \
	-ffunction-sections \
	-fdata-sections \
	-nostdinc \

# Add specific arch C flags (../arch_config/xxx/make.config)
CFLAGS += $(ARCH_CFLAGS)

# Includes directories
CFLAGS += $(addprefix -I, $(INCLUDE_DIRS))

#
# LDFLAGS
#

# common architecture option
LDFLAGS = \
	-nostdlib \
	-nostartfiles \
	-static \
	-lgcc \
	-Wl,--nmagic \
	-Wl,--gc-sections \

# Add specific arch LD options
LDFLAGS += $(ARCH_LDFLAGS)

#
# Targets
#

# Remove implicit rules 
.SUFFIXES:

# Include object dependencies generated by gcc
-include $(DEPFILES)

.PHONY: clean

$(LIB): $(OBJS)
	$(call cmd,LD $@, $(dir $@), \
	$(AR) cr $@ $(OBJS))

$(OBJ_DIR)/%.o: %.c Makefile
	$(call cmd,CC $<, $(dir $@), \
	$(CC) -c -o $@ $< -MMD -MP $(CFLAGS))


clean:
	rm -f $(LIB)
	rm -rf $(OBJ_DIR)

#
# To view commands use: make V=1
#

ifdef V
cmd = @mkdir -p $2 ; echo "$1 :\n$3"; $3
else
cmd = @echo "$1"; mkdir -p $2 ; $3
endif

