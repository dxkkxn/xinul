SHELL = /bin/sh
LIB_NAME ?= libc
BUILD_DIR ?= ../build
OBJ_DIR = $(BUILD_DIR)/$(LIB_NAME)_objs
LIB ?= $(BUILD_DIR)/$(LIB_NAME).a

#
# Objects and include headers directories
#

INCLUDE_DIRS = include include/arch/riscv

LIB_DIRS = stdin stdlib stdio string drivers arch/rv64
LIB_SRC = $(foreach d, $(LIB_DIRS), $(wildcard $(d)/*.c))
OBJS = $(sort $(LIB_SRC:.c=.o))
OBJS := $(addprefix $(OBJ_DIR)/, $(OBJS))
DEPFILES = $(OBJS:.o=.d)

#
# Import common cros-compile properties : tools, CFlags and  LDFlags
#

include ../riscv_flags.config

#
# CFlags
#

# Default optim and debug options
CFLAGS ?= -O0 -g

# common  arch options fetched from ../riscv_flags.config
CFLAGS += $(ARCH_CFLAGS)

# Add specific libc C flags
CFLAGS += $(addprefix -I, $(INCLUDE_DIRS))

#
# LDFLAGS
#

# common architecture options fetched from ../riscv_flags.config
LDFLAGS = $(ARCH_LDFLAGS)

# Add specific libc LD options
LDFLAGS += 

#
# Targets
#

# Remove implicit rules 
.SUFFIXES:

.PHONY: clean

$(LIB): $(OBJS)
	$(call cmd,LD $@, $(dir $@), \
	$(AR) cr $@ $(OBJS))

$(OBJ_DIR)/%.o: %.c Makefile ../riscv_flags.config
	$(call cmd,CC $< -> $@, $(dir $@), \
	$(CC) -c -o $@ $< -MMD -MP $(CFLAGS))

# Include object dependencies generated by gcc
-include $(DEPFILES)

clean:
	rm -f $(LIB)
	rm -rf $(OBJ_DIR)

#
# To view commands use: make V=1
#

ifdef V
cmd = @mkdir -p $2 ; echo "$1 :\n$3"; $3
else
cmd = @echo "$1"; mkdir -p $2 ; $3
endif

