# To view commands use: make V=1
#

SHELL = /bin/sh
ULIB_NAME ?= ulib
BUILD_DIR ?= ../../build
ULIB_OBJ_DIR = $(BUILD_DIR)/$(ULIB_NAME)_objs
ULIB_TARGET ?= $(BUILD_DIR)/$(ULIB_NAME).a

#
# Objects and include headers directories
#

ULIB_INCLUDES = .
#ULIB_INCLUDES := $(addprefix ../$(STDULIB_NAME)/, $(ULIB_INCLUDES)) # Useful if this Makefile is imported to an other.

ULIB_SRC_DIRS = .
#ULIB_SRC_DIRS := $(addprefix ../$(ULIB_NAME)/, $(ULIB_SRC_DIRS)) # Useful if this Makefile is imported to an other.
ULIB_SRC = $(foreach d, $(ULIB_SRC_DIRS), $(wildcard $(d)/*.c))
ULIB_ASM = $(foreach d, $(ULIB_SRC_DIRS), $(wildcard $(d)/*.S))
ULIB_OBJS = $(sort $(ULIB_SRC:.c=.o)) $(sort $(ULIB_ASM:.S=.o))
ULIB_OBJS := $(addprefix $(ULIB_OBJ_DIR)/, $(ULIB_OBJS))
ULIB_DEPFILES = $(ULIB_OBJS:.o=.d)


#
# CFlags
#

# Default optim and debug options
ULIB_CFLAGS ?= -O0 -g

# Import common cros-compile properties : tools, CFlags and  LDFlags
include ../../riscv_flags.config
ULIB_CFLAGS += $(ARCH_CFLAGS)

# Add specific libc C flags
ULIB_CFLAGS += $(addprefix -I, $(ULIB_INCLUDES))

#
# Targets
#

# Remove implicit rules 
.SUFFIXES:

.PHONY: clean

$(ULIB_TARGET) : $(ULIB_OBJS)
	$(call cmd,AR $@, $(dir $@), \
	$(AR) cr $@ $(ULIB_OBJS))

$(ULIB_OBJ_DIR)/%.o: %.c Makefile ../../riscv_flags.config
	$(call cmd,CC $< -> $@, $(dir $@), \
	$(CC) -c -o $@ $< -MMD -MP $(ULIB_CFLAGS))


$(ULIB_OBJ_DIR)/%.o: %.S Makefile ../../riscv_flags.config
	$(call cmd,AS $< -> $@, $(dir $@), \
	$(AS) -c -o $@ $< -MMD -MP $(ULIB_CFLAGS))

# Include object dependencies generated by gcc
-include $(ULIB_DEPFILES)

clean_lib:
	rm -f $(ULIB_TARGET) 
	rm -rf $(ULIB_OBJ_DIR)

#
# To view commands use: make V=1
#

ifdef V
cmd = @mkdir -p $2 ; echo "$1 :\n$3"; $3
else
cmd = @echo "$1"; mkdir -p $2 ; $3
endif

